# Vercel CLI (same project as serverless). Pulls go to .env.vercel.* (gitignored), not .env.local:
#   pnpm env:vercel          # Development → .env.vercel.development
#   pnpm env:vercel:prod     # Production  → .env.vercel.production
# Requires `vercel link`. Variables marked Sensitive in Vercel are NOT included in pulls — copy those
# from the dashboard into .env.local (e.g. NOTION_TOKEN).

# Authentication Configuration
REACT_APP_AUTH_PASSWORD=your_secure_password_here

# Notion Configuration (required for /api/content in local dev — the Vite server reads these)
# Either name works; NOTION_TOKEN avoids exposing the token to the browser bundle.
NOTION_TOKEN=your_notion_integration_token_here
# REACT_APP_NOTION_TOKEN=your_notion_integration_token_here

# Google Sheets Configuration (deprecated - replaced by Notion)
# REACT_APP_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
# REACT_APP_GOOGLE_SHEETS_DOC_ID=your_google_sheets_doc_id_here

# Printful API Configuration
# Get these values from your Printful dashboard
REACT_APP_PRINTFUL_API_KEY=your_printful_api_key_here
REACT_APP_PRINTFUL_CLIENT_ID=your_printful_client_id_here
REACT_APP_PRINTFUL_SECRET_KEY=your_printful_secret_key_here
REACT_APP_PRINTFUL_STORE_ID=your_store_id_here

# Development Configuration
SKIP_PREFLIGHT_CHECK=true
# Optional: where CRACO's dev proxy sends /api (default http://127.0.0.1:8080 when using pnpm dev)
# CONTENT_API_PROXY_TARGET=http://127.0.0.1:8080

# Analytics
# Set to "true" to enable the optional Vercel Analytics script in production builds.
# Leaving this unset (or any value other than "true") keeps the script disabled to
# avoid console warnings in environments without Web Analytics support.
REACT_APP_ENABLE_VERCEL_ANALYTICS=false
