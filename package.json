{
  "name": "portfolio",
  "version": "0.1.0",
  "homepage": "https://aaronwoods.info/",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "personal website"
  ],
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "unused-imports"
    ],
    "rules": {
      "unused-imports/no-unused-imports": "error"
    }
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "scripts": {
    "dev:api": "vite --port 8080 --strictPort",
    "dev:craco": "wait-on tcp:8080 && craco start --config config/craco.config.js",
    "start": "run-p dev:api dev:craco",
    "dev": "run-p dev:api dev:craco",
    "build": "vite build",
    "test": "react-scripts test --watchAll=false --passWithNoTests",
    "eject": "react-scripts eject",
    "format": "biome format ./src --write",
    "lint": "biome lint ./src",
    "check": "biome check --write .",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "sass:check": "sass --no-source-map --no-error-css --verbose src:public/build/css",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "compress-images": "node scripts/compress-images.js",
    "env:vercel": "vercel env pull .env.vercel.development --yes --environment development",
    "env:vercel:prod": "vercel env pull .env.vercel.production --yes --environment production",
    "build:dev": "vite build --mode development"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@eslint/config-array": "^0.23.4",
    "@eslint/object-schema": "^3.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.14.0",
    "canvas-confetti": "^1.9.4",
    "chalk": "^5.6.2",
    "chroma-js": "^3.2.0",
    "clean-css": "^5.3.3",
    "compression-webpack-plugin": "^11.1.0",
    "cors": "^2.8.6",
    "customize-cra": "^1.0.0",
    "deadfile": "^2.1.1",
    "eslint-config-react-app": "^7.0.1",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "lovable-tagger": "^1.1.13",
    "moment": "^2.30.1",
    "npm-run-all": "^4.1.5",
    "ogl": "^1.0.11",
    "open": "^10.2.0",
    "postcss-cli": "^11.0.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-db-google-sheets": "^3.0.0",
    "react-dom": "^19.2.4",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^7.14.0",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "styled-components": "^6.3.12",
    "terser-webpack-plugin": "^5.4.0",
    "tone": "^15.1.22",
    "vite": "^8.0.3",
    "web-vitals": "^5.2.0"
  },
  "bin": {
    "deadfile": "./deadfile.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@biomejs/biome": "^2.4.10",
    "@craco/craco": "^7.1.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/prop-types": "^15.7.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "babel-eslint": "^10.1.0",
    "css-select": "^6.0.0",
    "depcheck": "^1.4.7",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest-watch-typeahead": "^2.2.2",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "npm-check": "^6.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react-scripts": "^5.0.1",
    "resolve-url-loader": "^5.0.0",
    "sass-loader": "^13.3.3",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vercel": "^50.39.0",
    "wait-on": "^9.0.4"
  },
  "sassConfig": {
    "api": "modern",
    "sourceMap": true,
    "sourceMapEmbed": true
  },
  "resolutions": {
    "sass-loader": "^13.3.2",
    "postcss": "^8.5.6",
    "svgo": "^4.0.0",
    "css-select": "^6.0.0",
    "@svgr/webpack": "^8.1.0",
    "resolve-url-loader": "^5.0.0"
  },
  "overrides": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/guitarbeat/Personal-Website"
  }
}
